.env.test.local
.env.production.local

# Ignore logs and diagnostics
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# Ignore OS files
.DS_Store
Thumbs.db
